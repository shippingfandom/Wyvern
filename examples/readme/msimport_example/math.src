Math = {}
Math.classID = "Math"
Math._pi = null

Math.Pi = function
    return self._pi
end function
Math.Factorial = function(n)
    if n <= 0 then return 1
    return self.Factorial(n - 1) * n
end function

Math.New = function
    this = new Math
    this.classID = "Math"
    this._pi = 3.14
    return this
end function
