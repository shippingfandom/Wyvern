let a: number = 1;
let b: string = "2";

b = 2;          // Compilation error!
                // Can't assign number to a string variable

print(a + b);   // Compilation error!
                // Can't summate number and a string

print(a + cast<number>(b)); // Perfectly fine though!
print(a + b.val);           // Or even this (0.0 )
