contract Printable {
	public fn Print() -> void;
}

class Figure $ Printable {
	public fn Print() -> void {
		print("Figure!");
	}
}

class Entity $ Printable {
	public fn Print() -> void {
		print("Entity!");
	}
}

let printables: Printable[] = [
	new Figure(), new Entity()
];
foreach let p: Printable in printables {
	p.Print();
}
